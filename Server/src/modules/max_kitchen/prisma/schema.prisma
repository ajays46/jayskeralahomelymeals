  @@index([resolved_inventory_item_id], map: "ix_purchase_request_lines_resolved_inventory_item_id")
}

model purchase_request_operator_seen {
  company_id                    String   @db.VarChar(36)
  request_id                    String   @db.VarChar(36)
  user_id                       String   @db.VarChar(100)
  last_seen_content_revision_at DateTime @db.DateTime(0)
  created_at                    DateTime @db.DateTime(0)
  updated_at                    DateTime @db.DateTime(0)

  @@id([company_id, request_id, user_id])
  @@index([company_id, request_id], map: "idx_pr_operator_seen_req")
}

model purchase_requests {
  id             String    @id @db.VarChar(36)
  company_id     String    @db.VarChar(36)
  status         String    @db.VarChar(20)
  purchase_type  String    @default("AD_HOC") @db.VarChar(20)
  for_date       DateTime? @db.Date
  urgency        String    @default("NORMAL") @db.VarChar(20)
  requested_by   String?   @db.VarChar(100)
  requested_note String?   @db.VarChar(1000)
  submitted_at   DateTime? @db.DateTime(6)
  approved_by    String?   @db.VarChar(100)
  approval_note  String?   @db.VarChar(1000)
  approved_at    DateTime? @db.DateTime(0)
  created_at     DateTime  @db.DateTime(0)
  updated_at     DateTime  @db.DateTime(0)

  @@index([company_id, status], map: "idx_purchase_requests_company_status")
  @@index([submitted_at], map: "idx_purchase_requests_submitted_at")
  @@index([company_id], map: "ix_purchase_requests_company_id")
}

